# IronFlow - variables de entorno de ejemplo
# Copiar este archivo como .env para uso local si se requiere.
# No registrar credenciales reales en Git.

SPRING_PROFILES_ACTIVE=h2
EUREKA_DEFAULT_ZONE=http://discovery-server:8761/eureka/

# Credenciales locales de referencia para el API Gateway.
# Cambiar en entornos reales.
IRONFLOW_ADMIN_USER=admin
IRONFLOW_ADMIN_PASSWORD=change_me_admin
IRONFLOW_SOCIO_USER=socio
IRONFLOW_SOCIO_PASSWORD=change_me_socio
IRONFLOW_RECEPCIONISTA_USER=recepcion
IRONFLOW_RECEPCIONISTA_PASSWORD=change_me_recepcion

# Variables genericas para perfiles remotos con PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ironflow
DB_USER=ironflow_user
DB_PASSWORD=change_me

# Variables por servicio cuando se despliega cada base por separado.
MEMBER_DB_HOST=localhost
MEMBER_DB_PORT=5432
MEMBER_DB_NAME=db_members
MEMBER_DB_USER=ironflow_user
MEMBER_DB_PASSWORD=change_me

MEMBERSHIP_DB_HOST=localhost
MEMBERSHIP_DB_PORT=5432
MEMBERSHIP_DB_NAME=db_memberships
MEMBERSHIP_DB_USER=ironflow_user
MEMBERSHIP_DB_PASSWORD=change_me

PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5432
PAYMENT_DB_NAME=db_payments
PAYMENT_DB_USER=ironflow_user
PAYMENT_DB_PASSWORD=change_me

BOOKING_DB_HOST=localhost
BOOKING_DB_PORT=5432
BOOKING_DB_NAME=db_bookings
BOOKING_DB_USER=ironflow_user
BOOKING_DB_PASSWORD=change_me

CLASS_DB_HOST=localhost
CLASS_DB_PORT=5432
CLASS_DB_NAME=db_classes
CLASS_DB_USER=ironflow_user
CLASS_DB_PASSWORD=change_me

TRAINER_DB_HOST=localhost
TRAINER_DB_PORT=5432
TRAINER_DB_NAME=db_trainers
TRAINER_DB_USER=ironflow_user
TRAINER_DB_PASSWORD=change_me

ACCESS_DB_HOST=localhost
ACCESS_DB_PORT=5432
ACCESS_DB_NAME=db_access
ACCESS_DB_USER=ironflow_user
ACCESS_DB_PASSWORD=change_me

EQUIPMENT_DB_HOST=localhost
