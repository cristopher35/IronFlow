NOTIFICATION_DB_NAME=db_notifications
NOTIFICATION_DB_USER=ironflow_user
NOTIFICATION_DB_PASSWORD=change_me

# URLs internas o publicas por entorno.
MEMBER_SERVICE_URL=http://member-service:8081
MEMBERSHIP_SERVICE_URL=http://membership-service:8082
PAYMENT_SERVICE_URL=http://payment-service:8083
BOOKING_SERVICE_URL=http://booking-service:8085
CLASS_SERVICE_URL=http://class-service:8084
TRAINER_SERVICE_URL=http://trainer-service:8086
